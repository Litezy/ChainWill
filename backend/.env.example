# Backend Server Configuration
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/chainwill
DIRECT_URL=postgresql://user:password@localhost:5432/chainwill

# Web3 Configuration
RPC_URL=https://rpc.sepolia.org
CWT_ADDRESS=0x9b068dC0418064C11d9bc563edC26890DD95a60e

# Approval Event Listener Configuration
# Polling interval in milliseconds (default: 30000 = 30 seconds)
APPROVAL_POLL_INTERVAL=30000

# Effective Pull Amount Updater Configuration
# Update interval in milliseconds (default: 60000 = 60 seconds)
EFFECTIVE_AMOUNT_UPDATE_INTERVAL=60000

# Maximum number of parallel contract calls to prevent RPC overload
# (default: 5)
MAX_PARALLEL_UPDATES=5

# Fast inactivity monitor and alert engine
# Runs every minute via node-cron and checks active wills in batches
MONITOR_MAX_PARALLEL_CHECKS=5
NOTIFICATION_WORKER_AUTOSTART=true
NOTIFICATION_WORKER_CONCURRENCY=5
NOTIFICATION_JOB_ATTEMPTS=5
NOTIFICATION_JOB_BACKOFF_MS=10000

# Redis / BullMQ
# Either use a single REDIS_URL or the host/port credentials below.
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false
NOTIFICATION_QUEUE_NAME=chainwill-notifications

# Optional wallet->email fallback map for demo data or when emails are not yet
# persisted in the database, e.g. {"0xowner":"owner@example.com"}
ALERT_EMAIL_OVERRIDES={}

# Resend email delivery
# Leave RESEND_API_KEY empty to log email payloads locally instead of sending.
RESEND_API_KEY=
ALERT_EMAIL_FROM=ChainWill <onboarding@resend.dev>
ALERT_EMAIL_REPLY_TO=
